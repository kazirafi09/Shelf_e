##############################################################################
# Shelf-E — Production Environment Template
# Copy this file to .env and fill in every value marked <CHANGE_ME>.
# Lines marked [PROD] are the values that MUST differ from local defaults.
##############################################################################

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Shelf-E"
APP_ENV=production          # [PROD] Never "local" on a live server
APP_KEY=                    # Run: php artisan key:generate
APP_DEBUG=false             # [PROD] MUST be false — exposes stack traces & config if true
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Security ─────────────────────────────────────────────────────────────────
# Increase rounds for stronger password hashing (cost ≈ 300 ms/hash at 12)
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily           # [PROD] "daily" rotates logs; "single" grows unbounded
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error             # [PROD] MUST be "error" or "warning" — "debug" leaks SQL & user data to disk
LOG_DAILY_DAYS=14

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# For MySQL/Postgres on production, uncomment and fill in:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=<CHANGE_ME>
# DB_USERNAME=<CHANGE_ME>
# DB_PASSWORD=<CHANGE_ME>

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true        # [PROD] Encrypt session payload at rest
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com  # [PROD] Set to your domain (leading dot covers subdomains)
SESSION_SECURE_COOKIE=true  # [PROD] MUST be true — only send session cookie over HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict    # [PROD] "strict" is strongest; use "lax" only if you need cross-site POSTs

# ── Broadcasting / Cache / Queue ─────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ─────────────────────────────────────────────────────────────────────
# [PROD] MUST change MAIL_MAILER from "log" — password resets and order
#        confirmations are silently discarded with the log driver.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<CHANGE_ME>           # e.g. smtp.mailgun.org or smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=<CHANGE_ME>
MAIL_PASSWORD=<CHANGE_ME>
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (only required if using S3 for file storage or SES for mail) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Google OAuth (Socialite) ─────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<CHANGE_ME>
GOOGLE_CLIENT_SECRET=<CHANGE_ME>
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# ── Redis (only required if using Redis for cache/queue/sessions) ─────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
